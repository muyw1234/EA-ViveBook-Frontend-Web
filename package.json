{
  "name": "web-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint",
    "lint:quiet": "eslint --quiet",
    "lint:fix": "eslint --fix",
    "format": "prettier . --write",
