    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "firebase": "^12.15.0",
    "firebase-admin": "^13.10.0",
    "i18next": "^26.0.10",
    "jwt-decode": "^4.0.0",
    "leaflet": "^1.9.4",
    "matomo-tracker-for-react": "^2.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.7",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.0",
    "react-toastify": "^11.1.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
